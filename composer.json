{
    "name": "spiriitlabs/composer-update-report",
    "description": "Composer plugin that generates a Markdown report after each composer update",
    "type": "composer-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Anthony Delgado",
            "email": "adelgado@spiriit.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "composer-plugin-api": "^2.0"
    },
    "require-dev": {
        "composer/composer": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Spiriit\\ComposerUpdateReport\\": "src/"
        }
    },
    "extra": {
        "class": "Spiriit\\ComposerUpdateReport\\Plugin"
    },
    "scripts": {
        "cs-check": "vendor/bin/php-cs-fixer fix --verbose --diff --dry-run",
        "cs-fix": "vendor/bin/php-cs-fixer fix --verbose --diff",
        "test": "vendor/bin/phpunit"
    }
}
